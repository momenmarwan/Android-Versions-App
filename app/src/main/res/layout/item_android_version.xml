<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="7dp"
    android:layout_marginBottom="7dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/image_logo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/logo_content_description"
            android:src="@drawable/ic_donut"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/text_initial"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/image_logo"
            app:layout_constraintEnd_toEndOf="@id/image_logo"
            app:layout_constraintTop_toTopOf="@id/image_logo"
            app:layout_constraintBottom_toBottomOf="@id/image_logo"
            tools:text="L" />

        <TextView
            android:id="@+id/text_code_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/image_logo"
            app:layout_constraintEnd_toStartOf="@id/image_chevron"
            app:layout_constraintTop_toTopOf="@id/image_logo"
            app:layout_constraintBottom_toTopOf="@id/text_version"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Ice Cream Sandwich" />

        <TextView
            android:id="@+id/text_version"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/text_code_name"
            app:layout_constraintEnd_toEndOf="@id/text_code_name"
            app:layout_constraintTop_toBottomOf="@id/text_code_name"
            app:layout_constraintBottom_toBottomOf="@id/image_logo"
            tools:text="4.0 - 4.0.4" />

        <ImageView
            android:id="@+id/image_chevron"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/chevron_content_description"
            android:src="@drawable/ic_chevron"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
